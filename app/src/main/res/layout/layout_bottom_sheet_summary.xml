<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_bottom_sheet" android:orientation="vertical" android:padding="24dp">

    <!-- Handle (Garis kecil penanda tarik di atas) -->
    <View android:layout_width="40dp" android:layout_height="4dp" android:layout_gravity="center_horizontal" android:background="#D1D1D1" android:layout_marginBottom="24dp"/>

    <!-- Header (Ikon AI, Judul, Tombol X) -->
    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">

        <ImageView android:id="@+id/iv_ai_icon_popup" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_ai_star" android:layout_centerVertical="true"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ai Ringkas" android:textColor="@color/text_dark" android:textSize="18sp" android:textStyle="bold" android:layout_toEndOf="@id/iv_ai_icon_popup" android:layout_marginStart="12dp" android:layout_centerVertical="true"/>

        <ImageButton android:id="@+id/btn_close_sheet" android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_close" android:background="?attr/selectableItemBackgroundBorderless" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- Garis Pemisah Tipis -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp"/>

    <!-- Area Isi Ringkasan (Bisa di-scroll jika teksnya panjang) -->
    <ScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">

        <TextView android:id="@+id/tv_summary_result" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Q2 2026 roadmap focuses on four major initiatives: Mobile App Redesign, AI Integration, Collaboration Features, and Performance Optimization" android:textColor="@color/text_dark" android:textSize="14sp" android:lineSpacingExtra="6dp"/>
    </ScrollView>

    <!-- Tombol Copy Summary -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_copy_summary"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_button_purple"
        android:text="Copy Summary"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:drawableStart="@drawable/ic_copy"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"/>

</LinearLayout>