<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"> <!-- Agar aman dari status bar -->

    <!-- HEADER UNGU (Bagian Atas) -->
    <!-- HEADER UNGU (Bagian Atas) -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Tombol Kembali -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" />

        <!-- Teks Header (Diberi weight=1 agar mendorong tombol hapus ke kanan) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tv_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Untitled Note"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edited just now"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Tombol Hapus (Disembunyikan secara default menggunakan visibility="gone") -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:visibility="gone" />
    </LinearLayout>>

    <!-- AREA MENGETIK CATATAN (Bagian Tengah) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:layout_above="@id/bottom_bar"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Input Judul -->
        <EditText
            android:id="@+id/et_note_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Note title..."
            android:textColorHint="@color/black"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            android:inputType="textCapSentences"
            android:layout_marginBottom="16dp"/>

        <!-- Garis Pemisah Tipis -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A9D00FF"
            android:layout_marginBottom="16dp"/>

        <!-- Input Isi Catatan -->
        <EditText
            android:id="@+id/et_note_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="Start writing your thoughts..."
            android:textColorHint="@color/text_grey"
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:importantForAutofill="no" />
    </LinearLayout>

    <!-- TOMBOL SIMPAN & AI (Bagian Bawah) -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:background="@android:color/transparent">

        <!-- Tombol Save -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_save_note"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:background="@drawable/bg_button_purple"
            android:text="Save"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_save"
            android:drawablePadding="8dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#5C33FF" />

        <!-- Tombol Summarize (AI) yang sudah diperbaiki -->
        <LinearLayout
            android:id="@+id/btn_summarize"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:background="@drawable/bg_button_purple"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true">



            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_ai_star" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Summarize"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>